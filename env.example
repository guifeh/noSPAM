# ============================================
# CONFIGURAÇÃO DA EXTENSÃO Chrome (noSPAM)
# ============================================

# 1. Obtenha estas credenciais no Google Cloud Console:
#    https://console.cloud.google.com/apis/credentials

# OAuth Client ID (mesmo valor para extension/manifest.json e backend)
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com

# OAuth Client Secret (apenas para o backend)
GOOGLE_CLIENT_SECRET=seu_client_secret

# URI de redirecionamento (deve ser configurado no Google Cloud Console)
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ============================================
# APIs EXTERNAS
# ============================================

# Gemini API Key (obtenha em: https://aistudio.google.com/apikey)
GEMINI_API_KEY=sua_gemini_api_key

# ============================================
# EXTENSION (popup/src/Popup.jsx)
# ============================================

# Para desenvolvimento local, mantenha localhost
VITE_BACKEND_URL=http://localhost:8000
